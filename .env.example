# Copia este archivo a .env y completa tus valores. Nunca subas el .env real al repositorio.

# Proveedor del modelo de lenguaje: "anthropic" (por defecto) u "openai"
LLM_PROVIDER=anthropic

# --- Si usas LLM_PROVIDER=anthropic ---
# Clave de la API de Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de Claude a utilizar. Verifica los modelos vigentes en https://docs.claude.com
CLAUDE_MODEL=claude-sonnet-4-5

# --- Si usas LLM_PROVIDER=openai ---
# Clave de la API de OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de OpenAI a utilizar (gpt-4o-mini es económico y rápido; gpt-4o para mayor calidad)
OPENAI_MODEL=gpt-4o-mini

# Puerto local (Render lo asigna automáticamente en producción)
PORT=5000
